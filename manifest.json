{
  "manifest_version": 3,
  "name": "Turbo Browser — Speed & Queue Monitor",
  "version": "1.0.0",
  "description": "Speeds up page loads with DNS prefetch, preconnect injection, and real-time queue detection alerts.",
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "webNavigation",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Turbo Browser"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
